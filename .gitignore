```gitignore
# dependencies
node_modules/

# environment variables
.env
.env.*
!.env.example

# build output
dist/
build/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# TypeScript cache
*.tsbuildinfo

# coverage / test reports
coverage/

# optional cache folders
.cache/
.temp/
```
